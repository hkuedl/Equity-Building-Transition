    <file><filename>ssp585_2040s_Scenario_EPW_Scenario_EPW.json</filename><filetype>json</filetype><usage_type>resource</usage_type></file>
    <file><filename>ssp585_2050s_Scenario_EPW_Scenario_EPW.json</filename><filetype>json</filetype><usage_type>resource</usage_type></file>
  </files>
